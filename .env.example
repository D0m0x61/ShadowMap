# ShadowMap — API Keys
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is already in .gitignore.

# Shodan — required for the shodan module (ports, services, CVEs)
# Free account: https://account.shodan.io/register → My Account → API Key
SHODAN_API_KEY=your_shodan_api_key_here

# GitHub Personal Access Token — recommended for the leaks module
# Increases rate limit from 10 → 30 req/min. No scopes required.
# Generate at: https://github.com/settings/tokens (classic, all scopes unchecked)
GITHUB_TOKEN=your_github_token_here

# AbuseIPDB — required for the reputation module (1,000 checks/day free)
# Free account: https://www.abuseipdb.com/register → Account → API → Create Key
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# IPInfo — optional, improves geolocation accuracy (50k req/month free)
# Free account: https://ipinfo.io/signup → token shown on dashboard
IPINFO_TOKEN=your_ipinfo_token_here

# NVD API Key — recommended for the cves module
# Increases rate limit from 5 req/10s → 50 req/30s.
# Free: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Output directory for reports. Default: ./reports
OUTPUT_DIR=./reports

# Log verbosity: DEBUG | INFO | WARNING. Default: INFO
LOG_LEVEL=INFO
